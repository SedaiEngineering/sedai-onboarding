{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "commonreadcloudwatch",
            "Effect": "Allow",
            "Action": [
				"cloudwatch:DescribeAlarms",
				"cloudwatch:GetMetricData",
				"cloudwatch:ListMetrics",
				"cloudtrail:LookupEvents"
            ],
            "Resource": "*"
        },
        {
            "Sid": "commonreadiam",
            "Effect": "Allow",
            "Action": [
                "iam:ListInstanceProfiles"
            ],
            "Resource": "*"
        },
        {
            "Sid": "commonreadtag",
            "Effect": "Allow",
            "Action": [
                "tag:GetResources"
            ],
            "Resource": "*"
        }

    ]
}